# Credence Deployment Environment
# Copy to .env and fill in for testnet/mainnet deployments

# Deployer private key (Anvil default #0 used if not set)
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Fee recipient address (Anvil default #1 used if not set)
# FEE_RECIPIENT=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Protocol arbiter address (Anvil default #2 used if not set)
# PROTOCOL_ARBITER=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC

# RPC URLs (uncomment the one you need)
# ANVIL_RPC_URL=http://127.0.0.1:8545
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
